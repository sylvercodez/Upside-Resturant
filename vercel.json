{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/data/**",
          "firebase-applet-config.json"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}