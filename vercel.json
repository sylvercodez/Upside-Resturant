{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}