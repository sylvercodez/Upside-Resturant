{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 15,
      "includeFiles": "src/data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}