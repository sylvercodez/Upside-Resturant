{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 15,
      "includeFiles": "{src/data/**,src/utils/**,firebase-applet-config.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}