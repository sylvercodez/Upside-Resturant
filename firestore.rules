rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSystem() {
      return request.resource != null 
          && request.resource.data != null 
          && request.resource.data.systemWriteKey == "f8d3c501-4be5-4841-a6ab-cb5e1d4d03e9";
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() 
          && (
            (request.auth.token.email != null && (
              request.auth.token.email.lower() == "tosinotenaike3@gmail.com" || 
              request.auth.token.email.lower() == "tobi@gmail.com" ||
              request.auth.token.email.lower() == "mophethecommerce@gmail.com" ||
              request.auth.token.email.lower().matches('.*mophethecommerce.*')
            ))
            || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole(request.auth.uid) == "admin")
          );
    }

    function isSales() {
      return isSignedIn() 
          && (
            isAdmin()
            || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole(request.auth.uid) == "sales")
          );
    }

    function isChef() {
      return isSignedIn() 
          && (
            isAdmin()
            || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole(request.auth.uid) == "chef")
          );
    }

    function isValidOrder(data) {
      return data.userId is string 
          && data.userId.size() <= 128
          && data.customerName is string 
          && data.customerName.size() <= 200
          && data.email is string 
          && data.email.size() <= 150
          && data.phone is string 
          && data.phone.size() <= 50
          && data.totalPrice is number
          && data.items is list
          && data.status is string
          && data.timestamp is int
          && data.type is string;
    }

    // App and branding settings: publicly readable, validated writes (Admin-only or system)
    match /settings/branding {
      allow read: if true;
      allow write: if isAdmin() && request.resource.data.logoSvg is string 
                   && request.resource.data.logoSvg.size() <= 100000
                   && request.resource.data.brandName is string
                   && request.resource.data.brandName.size() <= 500
                   && request.resource.data.tagline is string
                   && request.resource.data.tagline.size() <= 500
                   && request.resource.data.subText is string
                   && request.resource.data.subText.size() <= 500;
    }

    // Instagram settings holding secrets: strictly isolated to admin only
    match /settings/instagram {
      allow read, write: if isAdmin();
    }

    // OPay payment integration settings: strictly isolated to admin only to be secure
    match /settings/opay {
      allow read, write: if isAdmin();
    }

    // Instagram posts feed: publicly readable, admin-only writes
    match /instagram_posts/{postId} {
      allow read, list: if true;
      allow write, create, update, delete: if isAdmin();
    }

    // User Profiles Rules
    match /users/{userId} {
      // Allow user themselves or admin to get details
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Allow only admin to list all users
      allow list: if isAdmin();
      
      // Create profile: enforce signed-in matches target node.
      // Prevent self-assigned privileged rights (default role 'user', unless bootstrapper or Admin override)
      allow create: if isSignedIn() 
                    && request.auth.uid == userId
                    && (request.resource.data.role == "user" 
                        || (request.resource.data.keys().hasAll(['email']) && (
                             request.resource.data.email.lower() == "tosinotenaike3@gmail.com" 
                             || request.resource.data.email.lower() == "tobi@gmail.com"
                             || request.resource.data.email.lower() == "mophethecommerce@gmail.com"
                             || request.resource.data.email.lower().matches('.*mophethecommerce.*')
                           ))
                        || isAdmin());

      // Update: user can modify their details as long as role remains untouched.
      allow update: if isSignedIn() 
                    && request.auth.uid == userId 
                    && request.resource.data.role == resource.data.role;

      // Allow bootstrap admin update
      allow update: if isSignedIn() 
                    && request.auth.uid == userId 
                    && (request.resource.data.keys().hasAll(['email']) && (
                         request.resource.data.email.lower() == "tosinotenaike3@gmail.com" 
                         || request.resource.data.email.lower() == "tobi@gmail.com"
                         || request.resource.data.email.lower() == "mophethecommerce@gmail.com"
                         || request.resource.data.email.lower().matches('.*mophethecommerce.*')
                       ))
                    && request.resource.data.role == "admin";

      // Admin can update anything
      allow update: if isAdmin();

      // Admin or owner can delete
      allow delete: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Menus Collection Rules
    match /menus/{menuItemId} {
      // Menus are publicly readable
      allow read, list: if true;
      
      // Only admin can write custom menus
      allow write, create, update, delete: if isAdmin();
    }

    // Categories Collection Rules
    match /categories/{categoryId} {
      // Categories are publicly readable
      allow read, list: if true;
      
      // Only admin can create, update, or delete categories
      allow write, create, update, delete: if isAdmin();
    }

    // Shipping Areas Collection Rules
    match /shipping_areas/{areaId} {
      allow read, list: if true;
      allow write, create, update, delete: if isAdmin();
    }

    // Site Image Assets Collection Rules
    match /assets/{assetId} {
      // Assets are publicly readable
      allow read, list: if true;
      
      // Only admin can manage assets
      allow write, create, update, delete: if isAdmin();
    }

    // Payments Collection Rules: Validate payment document structures
    function isValidPayment(data) {
      return data.orderId is string
          && data.orderId.size() <= 128
          && data.userId is string
          && data.userId.size() <= 128
          && data.amount is number
          && data.currency is string
          && data.currency.size() <= 10
          && data.paymentMethod is string
          && data.paymentMethod.size() <= 50
          && data.transactionReference is string
          && data.transactionReference.size() <= 128
          && data.paymentStatus is string
          && data.paymentStatus.size() <= 50;
    }

    match /payments/{paymentId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSales());
      allow create: if isSystem() || (
                    isSignedIn() 
                    && request.resource.data.userId == request.auth.uid 
                    && isValidId(paymentId)
                    && isValidPayment(request.resource.data)
                    );
      allow update: if isSystem() || (
                    isSignedIn() 
                    && (
                      (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidPayment(request.resource.data))
                      || isSales()
                    )
                    );
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      // Allow list and get options to owner or sales/admin staff
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSales());
      
      // Allow creation of order if the creator is the owner and the payload conforms to valid Order schemas
      allow create: if isSystem() || (
                    isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && isValidId(orderId)
                    && isValidOrder(request.resource.data)
                    );

      // Allow updates to own orders, or admin/sales pipeline updates (like cooking stages)
      allow update: if isSystem() || (
                    isSignedIn()
                    && (
                      (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data))
                      || isSales()
                    )
                    );

      // Admins can delete orders if necessary, standard users cannot
      allow delete: if isAdmin();
    }

    // Analytics Events Rules: Anyone can register events, but only administrators can read or query them
    function isValidAnalyticsEvent(data) {
      return data.eventType is string 
          && data.eventType.size() <= 64
          && data.timestamp is string
          && data.timestamp.size() <= 64;
    }

    match /analytics_events/{eventId} {
      allow create: if isValidId(eventId) && isValidAnalyticsEvent(request.resource.data);
      allow read, list: if isAdmin();
      allow update, delete: if false; // Security Invariant: Analytics events are immutable log files
    }
  }
}
